{
  "name": "gestor-financeiro",
  "version": "1.0.0",
  "description": "Monorepo: API + Web",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace=api && npm run dev --workspace=web",
    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "start": "npm start --workspace=api",
    "test": "npm test --workspace=api",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present"
  },
  "workspaces": [
    "api",
    "web"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
