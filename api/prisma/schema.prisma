generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  password  String?
  picture   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  categories      Category[]
  billings        Billing[]
  expenses        Expense[]
  recurrenceSkips RecurrenceSkip[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      CategoryType
  icon      String   @default("Tag")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  billings  Billing[]
  expenses  Expense[]

  @@unique([userId, name])
  @@map("categories")
}

model Billing {
  id            String      @id @default(uuid())
  value         Decimal     @db.Decimal(10, 2)
  description   String?
  recurring     Boolean     @default(false)
  startYear     Int?
  startMonth    Int?
  year          Int?
  month         Int?
  monthCreated  Int?
  yearCreated   Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("billings")
}

model Expense {
  id            String        @id @default(uuid())
  status        ExpenseStatus
  value         Decimal       @db.Decimal(10, 2)
  color         String        @default("#820AD1")
  recurring     Boolean       @default(false)
  startYear     Int?
  startMonth    Int?
  endYear       Int?
  endMonth      Int?
  year          Int?
  month         Int?
  monthCreated  Int?
  yearCreated   Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("expenses")
}

model RecurrenceSkip {
  id          String   @id @default(uuid())
  entityKind  String   // "billing" ou "expense"
  entityId    String
  year        Int
  month       Int
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, entityKind, entityId, year, month])
  @@map("recurrence_skips")
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum ExpenseStatus {
  PAID
  PENDING
}
