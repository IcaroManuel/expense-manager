generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  picture   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  billings        Billing[]
  expenses        Expense[]
  recurrenceSkips RecurrenceSkip[]
  balanceSnapshots       BalanceSnapshot[]
  investmentTransactions InvestmentTransaction[]

  @@map("users")
}

model Billing {
  id          String      @id @default(uuid())
  name        String
  type        BillingType
  value       Decimal     @db.Decimal(10, 2)
  recurring   Boolean     @default(false)
  startYear   Int?
  startMonth  Int?
  year        Int?
  month       Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billings")
}

model Expense {
  id          String        @id @default(uuid())
  name        String
  type        ExpenseType
  status      ExpenseStatus
  value       Decimal       @db.Decimal(10, 2)
  color       String        @default("#2D4238")
  recurring   Boolean       @default(false)
  startYear   Int?
  startMonth  Int?
  endYear     Int?
  endMonth    Int?
  year        Int?
  month       Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model RecurrenceSkip {
  id          String   @id @default(uuid())
  entityKind  String   // "billing" ou "expense"
  entityId    String
  year        Int
  month       Int
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, entityKind, entityId, year, month])
  @@map("recurrence_skips")
}

model BalanceSnapshot {
  id        String   @id @default(uuid())
  value     Decimal  @db.Decimal(10, 2)
  year      Int
  month     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@map("balance_snapshots")
}

model InvestmentTransaction {
  id        String          @id @default(uuid())
  type      TransactionType
  value     Decimal         @db.Decimal(10, 2)
  year      Int
  month     Int
  day       Int
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investment_transactions")
}

enum BillingType {
  SALARY
  AWARD
}

enum ExpenseType {
  FIXED
  CARD
  DETACHED
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

model NfseEmission {
  id           String   @id @default(uuid())
  year         Int
  month        Int
  numeroDps    String
  status       String   // PROCESSING | SUCCESS | FAILED
  chaveAcesso  String?
  rawResponse  Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month], name: "year_month")
}
